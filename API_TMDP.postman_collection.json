                  "});\r",
                  "\r",
                  "pm.test(\"Response contains results[] and dates{} object\", function () {\r",
                  "    pm.expect(response).to.have.property(\"results\");\r",
                  "    pm.expect(response.results).to.be.an(\"array\");\r",
                  "    pm.expect(response).to.have.property(\"dates\");\r",
                  "    pm.expect(response.dates).to.be.an(\"object\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"dates{} includes: maximum and minimum (date range) fields\", function () {\r",
                  "    pm.expect(response.dates).to.have.property(\"maximum\");\r",
                  "    pm.expect(response.dates).to.have.property(\"minimum\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Each movie includes: id, title, release_date, vote_count\", function () {\r",
                  "    response.results.forEach(movie => {\r",
                  "        pm.expect(movie).to.have.property(\"id\");\r",
                  "        pm.expect(movie).to.have.property(\"title\");\r",
                  "        pm.expect(movie).to.have.property(\"release_date\");\r",
                  "        pm.expect(movie).to.have.property(\"vote_count\");\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Confirm results are within the valid date range\", function () {\r",
                  "    const minimumDate = new Date(response.dates.minimum);\r",
                  "    const maximumDate = new Date(response.dates.maximum);\r",
