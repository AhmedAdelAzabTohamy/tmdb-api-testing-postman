              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "\r",
                  "\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "\r",
                  "pm.test(\"Response contains array\", function () {\r",
                  "    pm.expect(response.results).to.exist;\r",
                  "    pm.expect(response.results).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "\r",
                  "\r",
                  "\r",
                  "\r",
                  "pm.test(\"Validate movies contain ALL fields\", function () {\r",
                  "    response.results.forEach(movie => {\r",
                  "        pm.expect(movie).to.have.property(\"id\");\r",
                  "        pm.expect(movie).to.have.property(\"title\");\r",
                  "        pm.expect(movie).to.have.property(\"release_date\");\r",
                  "        pm.expect(movie).to.have.property(\"overview\");\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Validate that movie titles are relevant to the search keyword\", function () {\r",
                  "    const found = response.results.some(movie =>\r",
                  "        movie.title.toLowerCase().includes(\"inception\")\r",
                  "    );\r",
                  "\r",
                  "    pm.expect(found).to.be.true;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Confirm total_results > 0\", function () {\r",
                  "    pm.expect(response.results.length).to.be.above(0);\r",
                  "});"
                ],
